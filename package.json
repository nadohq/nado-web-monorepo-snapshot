{
  "name": "nado-web-monorepo",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf .turbo",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{js,json,jsx,ts,tsx,css,md}\" --log-level warn",
    "link-local-sdk": "./update-sdk-links.sh",
    "unlink-local-sdk": "UNLINK=true ./update-sdk-links.sh",
    "depcheck": "knip --dependencies",
    "depcheck:fix": "knip --dependencies --fix",
    "depcruise:all": "depcruise packages/* apps/*",
    "test:trade:e2e": "turbo run test:e2e"
  },
  "devDependencies": {
    "dependency-cruiser": "17.3.8",
    "husky": "9.1.7",
    "knip": "5.83.1",
    "lint-staged": "16.2.7",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-sort-json": "4.2.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "turbo": "2.8.8"
  },
  "engines": {
    "node": "24.x"
  },
  "catalog": {
    "@happy-dom/global-registrator": "20.6.1",
    "@next/bundle-analyzer": "16.2.1",
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-tabs": "1.1.13",
    "@tailwindcss/postcss": "4.1.18",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.9",
    "@types/d3-format": "3.0.4",
    "@types/lodash": "4.17.23",
    "@types/node": "24.10.7",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@nadohq/client": "0.8.0",
    "ahooks": "3.9.6",
    "bignumber.js": "10.0.2",
    "date-fns": "4.1.0",
    "d3-format": "3.1.2",
    "eslint": "9.35.0",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-turbo": "2.8.8",
    "i18next": "25.8.7",
    "jotai": "2.17.1",
    "lodash": "4.17.23",
    "next": "16.2.1",
    "postcss": "8.5.6",
    "next-sitemap": "4.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.4",
    "motion": "12.34.0",
    "react-popper-tooltip": "4.4.2",
    "recharts": "3.7.0",
    "safe-stable-stringify": "2.5.0",
    "sharp": "0.34.5",
    "tailwindcss": "4.1.18",
    "type-fest": "5.4.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0",
    "@typescript-eslint/eslint-plugin": "8.55.0",
    "viem": "2.45.3",
    "wagmi": "3.4.3",
    "zod": "4.3.6"
  },
  "packageManager": "bun@1.3.9"
}
