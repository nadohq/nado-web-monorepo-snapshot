{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "paths": {
      "@/*": ["src/*"]
    },
    "sourceMap": true,
    "target": "ESNext"
  },
  "exclude": ["node_modules"],
  "extends": "@nadohq/ts-config/base.json",
  "include": ["src/**/*.ts", "playwright.config.ts"]
}
