# E2E Test Environment Variables
# Copy this file to .env.local and fill in the values

# Required: Test wallet private key (testnet, with ETH for gas, and NADO pre-filled deposit)
# In CI: Set as GitHub Secret TEST_WALLET_PRIVATE_KEY
PRIVATE_KEY=0x...

# Optional: Target URL for tests
# In CI: Automatically set from Vercel Preview deployment
# Local: Defaults to http://localhost:3002
BASE_URL=http://localhost:3002
